# Oracle Engine — Environment Template
# Copy to .env and fill in. NEVER commit .env.

POLY_CLOB_HOST=https://clob.polymarket.com
POLY_GAMMA_HOST=https://gamma-api.polymarket.com
POLY_DATA_HOST=https://data-api.polymarket.com
POLY_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws
POLY_CHAIN_ID=137
POLY_PRIVATE_KEY=
POLY_PROXY_ADDRESS=
POLY_SIGNATURE_TYPE=0
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
ENGINE_MODE=paper
ENGINE_MAX_TOTAL_EXPOSURE_USDC=450
ENGINE_DAILY_LOSS_KILL_USDC=40
# Inventory management + PnL reconciliation (ALT-189)
ENGINE_Q_MAX_USDC=200
ENGINE_MIN_USDC_RESERVE=10
ENGINE_START_CAPITAL_USDC=50
ENGINE_PNL_DRIFT_TOLERANCE_USDC=5
ENGINE_PNL_DRIFT_TOLERANCE_PCT=0.05
POLY_RPC_URL=https://polygon-rpc.com
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
DATABASE_URL=sqlite:./state/oracle.db
PORT=3000
NODE_ENV=development
